#!/usr/bin/env bash
set -euo pipefail

# ── Conventional Commits message validator ────────────────────────────────────
#
# Enforces the format:
#   <type>[optional scope]: <description>
#
# Allowed types:
#   feat, fix, docs, style, refactor, perf, test, build, ci, chore, revert
#
# Examples:
#   feat: add VM snapshot support
#   fix(daemon): correct socket cleanup on shutdown
#   docs: update CHANGELOG for v0.2.0
#   chore(deps): bump tokio to 1.38

COMMIT_MSG_FILE="$1"
COMMIT_MSG="$(head -1 "$COMMIT_MSG_FILE")"

# Allow merge commits, cherry-picks, and reverts generated by git itself.
if echo "$COMMIT_MSG" | grep -qE '^(Merge |Revert |Applying: )'; then
  exit 0
fi

# Conventional commit pattern:
#   type(optional-scope): description
PATTERN='^(feat|fix|docs|style|refactor|perf|test|build|ci|chore|revert)(\([a-zA-Z0-9_/-]+\))?!?: .+'

if ! echo "$COMMIT_MSG" | grep -qE "$PATTERN"; then
  echo "ERROR: Commit message does not follow Conventional Commits format."
  echo ""
  echo "Expected: <type>[optional scope]: <description>"
  echo ""
  echo "Allowed types:"
  echo "  feat, fix, docs, style, refactor, perf, test, build, ci, chore, revert"
  echo ""
  echo "Examples:"
  echo "  feat: add VM snapshot support"
  echo "  fix(daemon): correct socket cleanup on shutdown"
  echo "  docs: update CHANGELOG for v0.2.0"
  echo ""
  echo "Your message was:"
  echo "  $COMMIT_MSG"
  exit 1
fi

# Enforce max subject line length (72 chars is the git convention).
MSG_LEN=${#COMMIT_MSG}
if [ "$MSG_LEN" -gt 72 ]; then
  echo "ERROR: Commit subject line is too long ($MSG_LEN chars, max 72)."
  echo "  $COMMIT_MSG"
  exit 1
fi
