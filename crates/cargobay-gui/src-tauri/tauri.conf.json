{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "CargoBay",
  "version": "1.0.0",
  "identifier": "com.cargobay.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://127.0.0.1:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "CargoBay",
        "width": 960,
        "height": 640,
        "minWidth": 680,
        "minHeight": 480,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "trayIcon": {
      "iconPath": "icons/icon.png",
      "iconAsTemplate": true,
      "tooltip": "CargoBay"
    },
    "security": {
      "csp": "default-src 'self'; img-src 'self' https: data:; script-src 'self'; style-src 'self' 'unsafe-inline'"
    }
  },
  "plugins": {
    "updater": {
      "active": false,
      "endpoints": ["https://github.com/coder-hhx/CargoBay/releases/latest/download/latest.json"],
      "dialog": false,
      "pubkey": ""
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
