{
  "$schema": "https://raw.githubusercontent.com/nicepkg/CrateBay/refs/heads/rewrite/v2/node_modules/@tauri-apps/cli/schema.json",
  "productName": "CrateBay",
  "version": "2.0.0",
  "identifier": "com.cratebay.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "title": "CrateBay",
        "width": 1400,
        "height": 900,
        "resizable": true,
        "fullscreen": false,
        "minWidth": 800,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": [
      "bin/cratebay-vz"
    ],
    "resources": [
      "runtime-images/README.md",
      "runtime-images/*/*",
      "runtime-linux/README.md",
      "runtime-linux/**/*",
      "runtime-wsl/README.md",
      "runtime-wsl/**/*",
      "bundle-images/README.md",
      "bundle-images/*"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/512x512.png",
      "icons/icon.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
