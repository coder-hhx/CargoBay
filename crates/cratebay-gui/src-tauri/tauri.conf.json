{
  "$schema": "https://raw.githubusercontent.com/nicepkg/CrateBay/refs/heads/rewrite/v2/node_modules/@tauri-apps/cli/schema.json",
  "productName": "CrateBay",
  "version": "2.0.0",
  "identifier": "com.cratebay.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "",
    "beforeBuildCommand": ""
  },
  "app": {
    "windows": [
      {
        "title": "CrateBay",
        "width": 1400,
        "height": 900,
        "resizable": true,
        "fullscreen": false,
        "minWidth": 800,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png"
    ]
  }
}
