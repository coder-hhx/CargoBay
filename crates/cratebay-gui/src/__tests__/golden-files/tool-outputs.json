{
  "container-list-two": {
    "description": "container_list tool output with 2 containers",
    "input": {},
    "mockResponse": [
      {
        "short_id": "abc123",
        "name": "node-01",
        "image": "node:20-slim",
        "state": "running",
        "cpu_cores": 2,
        "memory_mb": 2048
      },
      {
        "short_id": "def456",
        "name": "py-dev",
        "image": "python:3.12-slim",
        "state": "stopped",
        "cpu_cores": 1,
        "memory_mb": 1024
      }
    ],
    "expectedOutput": {
      "containsAll": [
        "2 container(s)",
        "node-01",
        "abc123",
        "running",
        "py-dev",
        "def456",
        "stopped"
      ]
    }
  },
  "container-list-empty": {
    "description": "container_list tool output with no containers",
    "input": {},
    "mockResponse": [],
    "expectedOutput": {
      "exact": "No containers found."
    }
  },
  "container-create-success": {
    "description": "container_create tool output on success",
    "input": {
      "name": "test-box",
      "image": "node:20-slim",
      "cpu_cores": 2,
      "memory_mb": 2048
    },
    "mockResponse": {
      "short_id": "ghi789",
      "name": "test-box",
      "image": "node:20-slim",
      "state": "running"
    },
    "expectedOutput": {
      "containsAll": [
        "test-box",
        "ghi789",
        "created successfully",
        "node:20-slim",
        "running"
      ]
    }
  },
  "container-exec-success": {
    "description": "container_exec tool output on successful command",
    "input": {
      "id": "abc123",
      "cmd": ["echo", "hello"]
    },
    "mockResponse": {
      "exit_code": 0,
      "stdout": "hello\n",
      "stderr": ""
    },
    "expectedOutput": {
      "containsAll": [
        "hello",
        "exit code:** 0"
      ]
    }
  },
  "container-exec-nonzero": {
    "description": "container_exec tool output with non-zero exit code and stderr",
    "input": {
      "id": "abc123",
      "cmd": ["cat", "/nonexistent"]
    },
    "mockResponse": {
      "exit_code": 1,
      "stdout": "",
      "stderr": "cat: /nonexistent: No such file or directory\n"
    },
    "expectedOutput": {
      "containsAll": [
        "exit code:** 1",
        "No such file or directory"
      ]
    }
  },
  "container-logs-output": {
    "description": "container_logs tool output with mixed stdout/stderr",
    "input": {
      "id": "abc123"
    },
    "mockResponse": [
      { "stream": "stdout", "message": "Server started on port 3000\n", "timestamp": null },
      { "stream": "stderr", "message": "DeprecationWarning: use X instead\n", "timestamp": null }
    ],
    "expectedOutput": {
      "containsAll": [
        "[stdout] Server started on port 3000",
        "[stderr] DeprecationWarning"
      ]
    }
  },
  "container-inspect-full": {
    "description": "container_inspect tool with full details",
    "input": {
      "containerId": "abc123"
    },
    "mockResponse": {
      "short_id": "abc123",
      "name": "node-01",
      "image": "node:20-slim",
      "state": "running",
      "created_at": "2026-03-20T10:00:00Z",
      "started_at": "2026-03-20T10:01:00Z",
      "cpu_cores": 2,
      "memory_mb": 2048,
      "env": ["NODE_ENV=production"],
      "ports": [{ "host_port": 3000, "container_port": 3000, "protocol": "tcp" }],
      "mounts": [],
      "network": { "ip_address": "172.17.0.2", "gateway": "172.17.0.1", "network_name": "bridge" }
    },
    "expectedOutput": {
      "containsAll": [
        "node-01",
        "abc123",
        "running",
        "2 cores",
        "2048 MB",
        "3000:3000/tcp",
        "172.17.0.2"
      ]
    }
  },
  "docker-status-connected": {
    "description": "docker_status tool when Docker is connected",
    "input": {},
    "mockResponse": {
      "connected": true,
      "version": "24.0.7",
      "api_version": "1.43",
      "os": "linux",
      "arch": "amd64",
      "source": "external",
      "socket_path": "/var/run/docker.sock"
    },
    "expectedOutput": {
      "containsAll": [
        "connected",
        "24.0.7",
        "1.43",
        "linux",
        "amd64"
      ]
    }
  },
  "docker-status-disconnected": {
    "description": "docker_status tool when Docker is not connected",
    "input": {},
    "mockResponse": {
      "connected": false,
      "version": null,
      "api_version": null,
      "os": null,
      "arch": null,
      "source": "external",
      "socket_path": "/var/run/docker.sock"
    },
    "expectedOutput": {
      "containsAll": [
        "not connected"
      ]
    }
  },
  "mcp-list-tools-empty": {
    "description": "mcp_list_tools when no servers are connected",
    "input": {},
    "mockResponse": [],
    "expectedOutput": {
      "containsAll": [
        "No MCP servers"
      ]
    }
  }
}
